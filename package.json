{
  "name": "stock-lookup",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "npm run start:full",
    "start:frontend": "ng serve",
    "start:backend": "mvn -f backend/pom.xml spring-boot:run",
    "start:full": "concurrently -k -n FRONTEND,BACKEND -c cyan,green \"npm run start:frontend\" \"npm run start:backend\"",
    "start:e2e": "ng serve --port 4201",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "deploy:vercel": "bash scripts/deploy-vercel.sh",
    "e2e:cypress:open": "cypress open",
    "e2e:cypress": "cypress run",
    "e2e:cypress:ci": "start-server-and-test start:e2e http://localhost:4201 \"cypress run --config baseUrl=http://localhost:4201\""
  },
  "private": true,
  "packageManager": "npm@11.11.0",
  "dependencies": {
    "@angular/common": "^21.2.0",
    "@angular/compiler": "^21.2.0",
    "@angular/core": "^21.2.0",
    "@angular/forms": "^21.2.0",
    "@angular/platform-browser": "^21.2.0",
    "@angular/router": "^21.2.0",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular/build": "^21.2.7",
    "@angular/cli": "^21.2.7",
    "@angular/compiler-cli": "^21.2.0",
    "concurrently": "^9.2.1",
    "jsdom": "^28.0.0",
    "prettier": "^3.8.1",
    "cypress": "^14.5.4",
    "start-server-and-test": "^2.1.2",
    "typescript": "~5.9.2",
    "vitest": "^4.0.8"
  }
}